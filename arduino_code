#include <SoftwareSerial.h>
SoftwareSerial sim(10, 11);
int _timeout;
String _buffer;
String number = "+40744873419"; //-> aici se adauga numarul si se poate schimba 
int led1 = 2;
int led2 = 4;
int led3 = 7;
int blinkCount1 = 0; 
int blinkCount2 = 0; 
int blinkCount3 = 0; 
bool shouldBlink1 = false; 
bool shouldBlink2 = false; 
bool shouldBlink3 = false; 


void setup() {
  pinMode(led1, OUTPUT);
  pinMode(led2, OUTPUT); 
  pinMode(led3, OUTPUT); 
  Serial.begin(9600);
  _buffer.reserve(50);
  Serial.println("Sistemul a pornit...");
  sim.begin(9600);
  delay(1000);
  Serial.println("Apasati litera s pentru a trimite mesaj sau litera a pentru a apela");
}

void loop() {
  if (Serial.available() > 0) {
    switch (Serial.read()) {
      case 's':
        SendMessage();
        shouldBlink1 = true;
        break;
      case 'r':
        RecieveMessage();
        break;
      case 'a':
        callNumber();
        shouldBlink2 = true;
        break;
    }
  }
  
  if (shouldBlink1) { 
    if (blinkCount1 < 30) { 
      digitalWrite(led2, HIGH);
      delay(150);
      digitalWrite(led2, LOW);
      delay(150);
      blinkCount1++;
    } else {
      shouldBlink1 = false;
    }
  }
  
  if (shouldBlink2) {
    if (blinkCount2 < 30) {
      digitalWrite(led1, HIGH);
      delay(500);
      digitalWrite(led1, LOW);
      delay(500);
      blinkCount2++; 
    } else {
      shouldBlink2 = false;
    }
  }
  
  if (sim.available() > 0) {
    Serial.write(sim.read());
  }
}

void SendMessage() {
  Serial.println ("Se trimite mesajul");
  sim.println("AT+CMGF=1");    
  delay(200);
  sim.println("AT+CMGS=\"" + number + "\"\r"); 
  delay(200);
  String SMS = "Este timpul pentru administrarea medicamentului din ziua de DUMINICA, compartimentul intermediar(mijloc) pentru pastilele de dupa-masa";
  sim.println(SMS);
  delay(100);
  sim.println((char)26);
  delay(200);
  _buffer = _readSerial();
}

void RecieveMessage() {
  Serial.println ("SIM800L Read an SMS");
  sim.println("AT+CMGF=1");
  delay (200);
  sim.println("AT+CNMI=1,2,0,0,0");
  delay(200);
  Serial.write ("Unread Message done");
}

String _readSerial() {
  _timeout = 0;
  while  (!sim.available() && _timeout < 12000) {
    delay(13);
    _timeout++;
  }
  if (sim.available()) {
    return sim.readString();
  }
}

void callNumber() {
  sim.print (F("ATD"));
  sim.print (number);
  sim.print (F(";\r\n"));
  _buffer = _readSerial();
  Serial.println(_buffer);
}
